// File: prisma/schema.prisma
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma-client" // Set the path to where the client will be generated
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  role          Role      @default(FAN)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts        Account[]
  sessions        Session[]
  artist          Artist? // One-to-one relation with Artist
  playlists       Playlist[]
  likedSongs      LikedSong[]
  followedArtists Follow[]
  photoLikes      PhotoLike[]
  subscriptions   Subscription[] // User can have multiple subscriptions over time
  payments        Payment[] // User can make multiple payments
  orders          Order[] // User can place multiple orders
  tickets         Ticket[] // User can have multiple tickets
  comments        Comment[] // User can make multiple comments
  photoComments   PhotoComment[] // User can make multiple photo comments
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Artist {
  id           String   @id @default(cuid())
  userId       String   @unique
  artistName   String
  bio          String?
  genres       String[]
  verified     Boolean  @default(false)
  profileImage String?
  coverImage   String?
  spotifyUrl   String?
  instagramUrl String?
  twitterUrl   String?
  youtubeUrl   String?
  website      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  songs       Song[]
  albums      Album[]
  followers   Follow[]
  photos      Photo[] // Artist photos
  photoAlbums PhotoAlbum[] // Photo albums
  revenues    ArtistRevenue[] // Artist's revenue records
  products    Product[] // Artist's merchandise products
  orders      Order[] // Orders related to this artist's products
}

model Song {
  id          String    @id @default(cuid())
  title       String
  artistId    String
  albumId     String?
  duration    Int
  audioUrl    String
  coverArt    String?
  lyrics      String?
  genre       String?
  releaseDate DateTime?
  isExplicit  Boolean   @default(false)
  streamCount Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  artist        Artist         @relation(fields: [artistId], references: [id])
  album         Album?         @relation(fields: [albumId], references: [id])
  likes         LikedSong[]
  playlistSongs PlaylistSong[]
  chartEntries  ChartEntry[]
  comments      Comment[] // Comments on this song
}

model Album {
  id          String    @id @default(cuid())
  title       String
  artistId    String
  coverArt    String?
  releaseDate DateTime?
  totalTracks Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  artist   Artist    @relation(fields: [artistId], references: [id])
  songs    Song[]
  comments Comment[] // Comments on this album
}

model Playlist {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  coverArt    String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user  User           @relation(fields: [userId], references: [id])
  songs PlaylistSong[]
}

model PlaylistSong {
  id         String @id @default(cuid())
  playlistId String
  songId     String
  order      Int

  // Relations
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  song     Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([playlistId, songId])
}

model LikedSong {
  id        String   @id @default(cuid())
  userId    String
  songId    String
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([userId, songId])
}

model Follow {
  id         String   @id @default(cuid())
  followerId String
  artistId   String
  createdAt  DateTime @default(now())

  // Relations
  follower User   @relation(fields: [followerId], references: [id], onDelete: Cascade)
  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([followerId, artistId])
}

model Chart {
  id          String    @id @default(cuid())
  name        String
  description String?
  type        ChartType
  country     String?
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime  @default(now())

  // Relations
  entries ChartEntry[]
}

model ChartEntry {
  id           String @id @default(cuid())
  chartId      String
  songId       String
  rank         Int
  previousRank Int?
  weeksOnChart Int    @default(1)

  // Relations
  chart Chart @relation(fields: [chartId], references: [id], onDelete: Cascade)
  song  Song  @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([chartId, songId])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  songId    String? // Optional: comment on a song
  albumId   String? // Optional: comment on an album
  content   String
  createdAt DateTime @default(now())

  // Relations
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  song  Song?  @relation(fields: [songId], references: [id], onDelete: Cascade)
  album Album? @relation(fields: [albumId], references: [id], onDelete: Cascade)

  // Ensure a comment is linked to either a song or an album, but not necessarily both
  // This constraint might need application-level logic or a more complex schema if required
}

// MODELS FOR PHOTO SHARING

model Photo {
  id           String    @id @default(cuid())
  artistId     String
  albumId      String?
  url          String
  thumbnailUrl String?
  caption      String?
  location     String?
  latitude     Float?
  longitude    Float?
  takenAt      DateTime?
  order        Int?
  likeCount    Int       @default(0)
  commentCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  artist   Artist         @relation(fields: [artistId], references: [id], onDelete: Cascade)
  album    PhotoAlbum?    @relation(fields: [albumId], references: [id], onDelete: SetNull)
  likes    PhotoLike[]
  comments PhotoComment[]
}

model PhotoAlbum {
  id           String   @id @default(cuid())
  artistId     String
  title        String
  description  String?
  coverPhotoId String? // Optional: ID of a photo that serves as the album cover
  isPublic     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  artist Artist  @relation(fields: [artistId], references: [id], onDelete: Cascade)
  photos Photo[]
}

model PhotoLike {
  id        String   @id @default(cuid())
  userId    String
  photoId   String
  createdAt DateTime @default(now())

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([userId, photoId])
}

model PhotoComment {
  id        String   @id @default(cuid())
  userId    String
  photoId   String
  content   String
  createdAt DateTime @default(now())

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)
}

// ENUMS

enum Role {
  FAN
  ARTIST
  ADMIN
}

enum ChartType {
  WEEKLY
  MONTHLY
  YEARLY
  ALL_TIME
}

enum PaymentType {
  SUBSCRIPTION
  TIP
  MERCHANDISE
  TICKET
}

// Consolidated Subscription model
model Subscription {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id])
  stripeSubscriptionId String   @unique // Stripe subscription ID
  stripePriceId        String // Stripe price ID for the tier
  status               String // e.g., 'active', 'canceled', 'past_due'
  currentPeriodStart   DateTime // Start of the current billing period
  currentPeriodEnd     DateTime // End of the current billing period
  cancelAtPeriodEnd    Boolean  @default(false) // Whether the subscription will cancel at the end of the period
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Optional: Link payments specifically for this subscription
  payments Payment[]

  @@index([userId])
  @@index([stripeSubscriptionId])
}

// Consolidated Payment model
model Payment {
  id                    String      @id @default(cuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id])
  stripePaymentIntentId String      @unique // Stripe Payment Intent ID or Charge ID
  amount                Float // Amount in currency units (e.g., dollars)
  currency              String      @default("usd")
  status                String // e.g., 'succeeded', 'pending', 'failed'
  type                  PaymentType // Use enum for clarity: 'subscription', 'tip', 'merchandise', 'ticket'
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  // Optional: Link to the subscription this payment is for (if type is SUBSCRIPTION)
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  // Relations to items purchased or revenue generated
  artistRevenue ArtistRevenue[]
  orders        Order[] // Payments can be for orders (merchandise)

  @@index([userId])
  @@index([stripePaymentIntentId])
  @@index([subscriptionId]) // Add index for subscription relation
}

model ArtistRevenue {
  id          String      @id @default(cuid())
  artistId    String
  artist      Artist      @relation(fields: [artistId], references: [id])
  paymentId   String
  payment     Payment     @relation(fields: [paymentId], references: [id])
  amount      Float // Amount of revenue for the artist (after platform fee)
  platformFee Float // Amount of platform fee deducted
  type        PaymentType // Use enum: 'tip', 'merchandise', 'streaming', 'tickets' (should align with Payment type)
  paid        Boolean     @default(false) // Whether this revenue has been paid out to the artist
  paidAt      DateTime? // Timestamp when the revenue was paid out
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([artistId])
  @@index([paymentId])
}

model Product {
  id          String      @id @default(cuid())
  artistId    String
  artist      Artist      @relation(fields: [artistId], references: [id])
  name        String
  description String?
  price       Float
  image       String
  inStock     Boolean     @default(true)
  category    String? // 'clothing', 'accessories', 'vinyl', 'digital'
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([artistId])
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  artistId  String? // Optional: If the order is for a specific artist's merchandise
  artist    Artist?     @relation(fields: [artistId], references: [id])
  paymentId String // Link to the payment for this order
  payment   Payment     @relation(fields: [paymentId], references: [id])
  total     Float // Total amount of the order
  status    String // 'pending', 'paid', 'shipped', 'delivered', 'canceled'
  items     OrderItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
  @@index([artistId])
  @@index([paymentId])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float // Price per item at the time of order
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

model Ticket {
  id        String   @id @default(cuid())
  eventId   String // Assuming an Event model exists or will exist
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  price     Float
  type      String // 'general', 'vip', 'backstage'
  status    String // 'active', 'used', 'canceled'
  qrCode    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Assuming a relation to an Event model would be added here
  // event Event @relation(fields: [eventId], references: [id])

  @@index([userId])
  @@index([eventId])
}
